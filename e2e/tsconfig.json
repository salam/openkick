{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": { "@helpers/*": ["helpers/*"], "@fixtures/*": ["fixtures/*"] }
  },
  "include": ["**/*.ts"]
}
